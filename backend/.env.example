# Server
PORT=3000
BASE_URL=https://your-server.ngrok.io

# 보건소 대시보드 로그인 (대시보드 /demo /users 관리 API 보호)
ADMIN_PASSWORD=../
ADMIN_API_TOKEN=change-this-to-a-long-random-string

# 시연용 농업인 (하나 이상 설정)
# DEMO_USER_ID=
# DEMO_USER_PHONE=
# DEMO_USER_NAME=

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Twilio (Voice + SMS)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your-auth-token
TWILIO_PHONE_NUMBER=+8210xxxxxxxx
HEALTH_CENTER_PHONE=+8254xxxxxxxx

# Clova Speech (Naver Cloud Platform)
CLOVA_SPEECH_INVOKE_URL=https://clovaspeech-gw.ncloud.com/recog/v1/stt
CLOVA_SPEECH_SECRET=your-clova-secret

# Claude (Anthropic)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx

# Slack
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx

# 외부 API
KMA_API_KEY=your-kma-api-key
KAKAO_MAP_API_KEY=your-kakao-map-api-key
